# Copy this file to `.env` and fill in real values for local development.
# `.env` is gitignored. NEVER commit a populated copy.

# ---- Market selection ---------------------------------------------------
# Which persona/locale this deployment serves. One of: UK, US
MARKET=UK

# ---- Gemini -------------------------------------------------------------
GEMINI_API_KEY=replace-with-your-gemini-api-key
FALLBACK_GEMINI_API_KEY=replace-with-fallback-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODEL=gemini-2.5-flash

# ---- HuggingFace (SDXL cover image) -------------------------------------
HUGGINGFACE_API_KEY=replace-with-your-hf-api-key

# ---- Google Cloud Storage -----------------------------------------------
# Bucket holds topic_history.json and (on Drive failure) fallback ZIPs.
GCS_BUCKET=your-gcs-bucket-name

# ---- Google Drive -------------------------------------------------------
# Shared folder where the day's three ZIPs land.
DRIVE_FOLDER_ID=replace-with-drive-folder-id
# Archive subfolder, counted to compute pricing.
DRIVE_ARCHIVE_FOLDER_ID=replace-with-archive-folder-id

# ---- Gmail summary email -------------------------------------------------
GMAIL_SENDER=sender@example.com
GMAIL_RECIPIENT=you@example.com

# ---- GCP credentials -----------------------------------------------------
# Path to the service-account JSON used by GCS, Drive, Gmail clients.
# In Cloud Run, this is mounted from Secret Manager.
GOOGLE_APPLICATION_CREDENTIALS=./secrets/service-account.json

# ---- Pricing -------------------------------------------------------------
LAUNCH_FREE_COUNT=30
PAID_PRICE_GBP=2.50
