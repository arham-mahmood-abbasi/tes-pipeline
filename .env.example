# Copy this file to `.env` and fill in real values for local development.
# `.env` is gitignored. NEVER commit a populated copy.

# ---- Market selection ---------------------------------------------------
# Which persona/locale this deployment serves. One of: UK, US
MARKET=UK

# ---- Gemini -------------------------------------------------------------
GEMINI_API_KEY=replace-with-your-gemini-api-key
FALLBACK_GEMINI_API_KEY=replace-with-fallback-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODEL=gemini-2.5-flash

# ---- NVIDIA (FLUX.1 cover image, primary tier) --------------------------
# Get a key at https://build.nvidia.com (nvapi-...). Optionally override the
# image model (defaults to black-forest-labs/flux.1-schnell).
NVIDIA_API_KEY=replace-with-your-nvidia-api-key
# NVIDIA_IMAGE_MODEL=black-forest-labs/flux.1-schnell

# ---- Pexels (stock-photo cover image, middle-tier fallback) -------------
# Used when the NVIDIA call fails or NVIDIA_API_KEY is unset.
# Get a free key at https://www.pexels.com/api/. Leave blank to skip the
# Pexels tier and go straight from NVIDIA to the Pillow placeholder.
PEXELS_API_KEY=replace-with-your-pexels-api-key

# ---- Local-filesystem paths ---------------------------------------------
# Where the orchestrator reads/writes state and writes the daily ZIPs.
# Both default to relative paths under the project root if unset.
HISTORY_FILE_PATH=./state/topic_history.json
OUTPUT_DIR=./output

# ---- Gmail summary email -------------------------------------------------
# Sends via SMTP (smtp.gmail.com:587 with STARTTLS) using an App Password.
# Generate one at https://myaccount.google.com/apppasswords (requires 2FA on).
# The day's three ZIPs are attached to the same email (well under Gmail's
# 25 MB cap).
GMAIL_SENDER=sender@example.com
GMAIL_RECIPIENT=you@example.com
GMAIL_APP_PASSWORD=replace-with-16-char-app-password

# ---- Pricing -------------------------------------------------------------
# Price written into every worksheet's tags.json. Default 0.0 (free).
# Change to (e.g.) 2.50 when you're ready to start charging on Tes.
PAID_PRICE_GBP=0.0
